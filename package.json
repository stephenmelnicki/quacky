{
  "name": "@quacky/monorepo",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "description": "A Discord bot for Marble Wednesdays",
  "author": "Stephen Melnicki",
  "license": "MIT",
  "repository": "github:stephenmelnicki/quacky",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "docs": "pnpm run --filter docs dev",
    "bot": "pnpm run --filter bot build && pnpm run --filter bot start"
  },
  "devDependencies": {
    "@eslint/js": "catalog:eslint",
    "eslint": "catalog:eslint",
    "eslint-plugin-format": "catalog:eslint",
    "eslint-plugin-prettier": "catalog:eslint",
    "lint-staged": "catalog:utils",
    "prettier": "catalog:eslint",
    "pnpm": "catalog:utils",
    "simple-git-hooks": "catalog:utils",
    "typescript": "catalog:typescript",
    "typescript-eslint": "catalog:eslint"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,md}": "eslint --cache --fix"
  },
  "dependencies": {
    "eslint-config-prettier": "catalog:eslint",
    "eslint-plugin-prettier": "catalog:eslint",
    "prettier": "catalog:eslint"
  }
}
